classDiagram
    class Owner {
        -String id
        -String name
        -List~String~ petIds
        +getName() String
        +getPets() List~Pet~
    }

    class Pet {
        -String id
        -String name
        -String ownerId
        -String breed
        -Schedule schedule
        +getName() String
        +getBreed() String
        +getOwner() Owner
        +getSchedule() Schedule
    }

    class Task {
        -String action
        -int duration
        -String priority
        +getAction() String
        +getDuration() int
        +getPriority() String
    }

    class Schedule {
        -String petId
        -Map~Time, Task~ tasks
        +addTask(Task task) void
        +removeTask(Task task) void
    }

    Owner "1" --> "many" Pet : owns
    Pet "1" --> "1" Schedule : has
    Schedule "1" --> "many" Task : contains
